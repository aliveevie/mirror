# =============================================================
# Mirror Protocol — environment template.
# Copy this to `.env`. Never commit your real `.env`.
# All values below are placeholders.
# =============================================================

# --- Arc testnet -----------------------------------------------
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# --- Token addresses (Arc testnet, verified from Circle docs) --
ADDR_USDC=0x3600000000000000000000000000000000000000
ADDR_USYC=0xe9185F0c5F296Ed1797AaE4238D26CCaBEadb86C

# --- Deployed Mirror contracts (fill after `forge script Deploy --broadcast`)
ADDR_LEADER_REGISTRY=
ADDR_ALLOCATION_ROUTER=
ADDR_RISK_CIRCUIT_BREAKER=
ADDR_BUILDER_FEE_WRAPPER=
ADDR_IDLE_RESERVE=

# --- Roles read by Deploy.s.sol --------------------------------
# AGENT_WALLET = your Circle Developer-Controlled Wallet address.
# All other roles can stay on the deployer EOA for testnet.
AGENT_WALLET=
EXECUTOR=
TREASURY=
REBATE_POOL=
AGENT_OPS_WALLET=

# --- Deployer (keystore-based; no plaintext key) ---------------
DEPLOYER_ADDRESS=

# --- Circle Developer Platform ---------------------------------
# Create at https://console.circle.com/wallets/dev/api-keys
CIRCLE_API_KEY=
# 32-byte hex entity secret. NEVER sent to Circle in plaintext;
# the agent encrypts under Circle's public RSA key per request.
# Generate: `openssl rand -hex 32`, then register at
# https://developers.circle.com/wallets/dev-controlled/register-entity-secret
CIRCLE_ENTITY_SECRET=
CIRCLE_AGENT_WALLET_ID=
CIRCLE_AGENT_WALLET_ADDRESS=
CIRCLE_WALLET_SET_ID=
CIRCLE_PAYMASTER_URL=
CIRCLE_GATEWAY_URL=
CIRCLE_CCTP_URL=

# --- Content-addressed storage for reasoning artifacts ---------
# Pinata example: ARTIFACT_PIN_ENDPOINT=https://api.pinata.cloud/pinning/pinJSONToIPFS
# Set both to empty to disable pinning (hash is still committed on-chain).
ARTIFACT_PIN_ENDPOINT=
ARTIFACT_PIN_TOKEN=

# --- Venue connectors (testnet) --------------------------------
HYPERLIQUID_TESTNET_URL=https://api.hyperliquid-testnet.xyz
POLYMARKET_TESTNET_URL=

# Hyperliquid testnet leader wallet private key (used by the leader EOA, not the agent).
# Optional; only needed if you want to drive leader actions from this repo's scripts.
HYPERLIQUID_TESTNET_WALLET=

# --- Supervisor runtime ----------------------------------------
# Comma-separated list of leader addresses the supervisor watches.
WATCHED_LEADERS=
# Loop interval in ms (15s default for testnet demos).
LOOP_INTERVAL_MS=15000

# --- Arcscan verification (optional) ---------------------------
ARCSCAN_API_KEY=unset
